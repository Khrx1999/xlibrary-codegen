root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Robot Framework files use 4-space indentation by convention.
[*.robot]
indent_size = 4

# Markdown: trailing spaces are meaningful (line break = two trailing spaces).
[*.md]
trim_trailing_whitespace = false
